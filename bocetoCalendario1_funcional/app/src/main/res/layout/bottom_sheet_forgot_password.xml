<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_handle" />

    <!-- FORM STATE -->
    <LinearLayout
        android:id="@+id/layoutFormForgot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Icon -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp">
            <View
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_icon_circle_brand" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✉"
                android:textSize="28sp" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recuperar contraseña"
            android:textColor="@color/ink"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Introduce tu correo y te enviaremos un enlace para restablecer tu contraseña."
            android:textColor="@color/muted"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:lineSpacingMultiplier="1.4" />

        <EditText
            android:id="@+id/etEmailForgot"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="tu@correo.com"
            android:inputType="textEmailAddress"
            android:background="@drawable/bg_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            android:textColor="@color/ink"
            android:textColorHint="@color/muted_2"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnEnviarEnlace"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Enviar enlace"
            android:backgroundTint="@color/brand"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- SUCCESS STATE -->
    <LinearLayout
        android:id="@+id/layoutSuccessForgot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:gravity="center"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp">
            <View
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_icon_circle_green" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✓"
                android:textSize="32sp"
                android:textColor="#22C55E"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Revisa tu bandeja"
            android:textColor="@color/ink"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvEmailConfirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/muted"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnEntendido"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Entendido"
            android:backgroundTint="@color/brand"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
