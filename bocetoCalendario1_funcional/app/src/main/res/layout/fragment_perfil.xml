<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Header label -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERFIL"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/brand"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/perfil"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/ink"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Profile card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card">

            <!-- Blue gradient banner -->
            <View
                android:id="@+id/viewBanner"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_profile_banner" />

            <!-- Avatar overlapping banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="-36dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tvInicialUsuario"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="U"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/bg_avatar_ring"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre del usuario"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/ink"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="email@ejemplo.com"
                    android:textSize="13sp"
                    android:textColor="@color/muted"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvIdUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="@color/muted_2"
                    android:layout_marginTop="2dp"
                    android:visibility="gone" />

                <!-- Edit profile button -->
                <TextView
                    android:id="@+id/btnEditarPerfil"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Editar perfil"
                    android:textSize="13sp"
                    android:textColor="@color/brand"
                    android:background="@drawable/bg_btn_ghost"
                    android:gravity="center"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:layout_marginTop="10dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Stats grid: 3 columns -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp">

            <!-- Eventos -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/bg_card"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/tvStatEventos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Eventos"
                    android:textSize="11sp"
                    android:textColor="@color/muted" />

            </LinearLayout>

            <!-- Grupos -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/bg_card"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/tvStatGrupos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/cat_magenta" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grupos"
                    android:textSize="11sp"
                    android:textColor="@color/muted" />

            </LinearLayout>

            <!-- Próximos -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/bg_card">

                <TextView
                    android:id="@+id/tvStatProximos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/cat_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Próximos"
                    android:textSize="11sp"
                    android:textColor="@color/muted" />

            </LinearLayout>

        </LinearLayout>

        <!-- PREFERENCIAS section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PREFERENCIAS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/muted"
            android:letterSpacing="0.06"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card">

            <!-- Modo oscuro -->
            <LinearLayout
                android:id="@+id/rowModoOscuro"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="🌙"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Modo oscuro"
                    android:textSize="15sp"
                    android:textColor="@color/ink"
                    android:paddingStart="8dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchModoOscuro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/line_2" android:layout_marginStart="16dp" />

            <!-- Notificaciones -->
            <LinearLayout
                android:id="@+id/rowNotificaciones"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="🔔"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Notificaciones"
                    android:textSize="15sp"
                    android:textColor="@color/ink"
                    android:paddingStart="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="@color/muted_2" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/line_2" android:layout_marginStart="16dp" />

            <!-- Idioma -->
            <LinearLayout
                android:id="@+id/rowIdioma"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="🌐"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Idioma"
                    android:textSize="15sp"
                    android:textColor="@color/ink"
                    android:paddingStart="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="@color/muted_2" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/line_2" android:layout_marginStart="16dp" />

            <!-- Privacidad -->
            <LinearLayout
                android:id="@+id/rowPrivacidad"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="🔐"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Privacidad"
                    android:textSize="15sp"
                    android:textColor="@color/ink"
                    android:paddingStart="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="@color/muted_2" />

            </LinearLayout>

        </LinearLayout>

        <!-- CUENTA section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CUENTA"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/muted"
            android:letterSpacing="0.06"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card">

            <!-- Ajustes -->
            <LinearLayout
                android:id="@+id/rowAjustes"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="⚙️"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ajustes"
                    android:textSize="15sp"
                    android:textColor="@color/ink"
                    android:paddingStart="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="@color/muted_2" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/line_2" android:layout_marginStart="16dp" />

            <!-- Cerrar sesión -->
            <LinearLayout
                android:id="@+id/btnCerrarSesion"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="🚪"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/cerrar_sesion"
                    android:textSize="15sp"
                    android:textColor="@color/cat_magenta"
                    android:textStyle="bold"
                    android:paddingStart="8dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Version label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calendario · v1.0.0"
            android:textSize="12sp"
            android:textColor="@color/muted_2"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

    </LinearLayout>

</ScrollView>
