<?xml version="1.0" encoding="utf-8"?>
<!--
    Pantalla de inicio de sesión.

    Estructura visual:
    ┌─────────────────────────────────────┐
    │   [Cabecera azul con logo + título] │  ← 40% de la pantalla
    │                                     │
    ├─────────────────────────────────────┤
    │   [Tarjeta blanca con formulario]   │  ← 60% restante
    │     Email + Contraseña + Botón      │
    └─────────────────────────────────────┘
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary">

    <!-- ─── CABECERA: identidad visual de la app ─── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="16dp"
        android:paddingTop="40dp">

        <!-- Icono circular de la aplicación -->
        <TextView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="📅"
            android:textSize="32sp"
            android:gravity="center"
            android:background="@drawable/bg_avatar_placeholder"
            android:backgroundTint="#33FFFFFF"
            android:layout_marginBottom="16dp"/>

        <!-- Nombre de la aplicación -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calendario"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.01"/>

        <!-- Slogan / descripción breve -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Organiza tu tiempo, simplifica tu vida"
            android:textSize="13sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginTop="6dp"/>

    </LinearLayout>

    <!-- ─── FORMULARIO: tarjeta blanca con esquinas superiores redondeadas ─── -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white">

        <!-- Contenedor con scroll por si la pantalla es pequeña -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp"
                android:paddingTop="32dp">

                <!-- Título del formulario -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Iniciar sesión"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bienvenido de nuevo"
                    android:textSize="14sp"
                    android:textColor="@color/gray"
                    android:layout_marginBottom="28dp"/>

                <!-- ─── Campo: correo electrónico ─── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/email"
                    android:layout_marginBottom="16dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="@color/gray">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"
                        android:singleLine="true"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ─── Campo: contraseña con toggle de visibilidad ─── -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/contrasena"
                    android:layout_marginBottom="28dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:endIconMode="password_toggle"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:startIconTint="@color/gray">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etContrasena"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:singleLine="true"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ─── Botón principal: iniciar sesión ─── -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="@string/iniciar_sesion"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="14dp"
                    android:layout_marginBottom="20dp"/>

                <!-- ─── Enlace a la pantalla de registro ─── -->
                <TextView
                    android:id="@+id/tvIrRegistro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_tienes_cuenta"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:layout_gravity="center"
                    android:padding="8dp"/>

            </LinearLayout>

        </ScrollView>

    </androidx.cardview.widget.CardView>

</LinearLayout>
