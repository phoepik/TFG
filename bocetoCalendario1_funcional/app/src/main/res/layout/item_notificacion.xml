<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" app:cardCornerRadius="8dp" app:cardElevation="2dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:id="@+id/tvIcono" android:layout_width="40dp" android:layout_height="40dp" android:text="🔔" android:textSize="20sp" android:gravity="center" android:background="@color/light_gray"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp">
                <TextView android:id="@+id/tvTituloNotif" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Título notificación" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/black"/>
                <TextView android:id="@+id/tvMensaje" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mensaje de la notificación" android:textSize="14sp" android:textColor="@color/gray" android:maxLines="2"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
                    <TextView android:id="@+id/tvTipo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RECORDATORIO" android:textSize="10sp" android:textColor="@color/primary" android:background="@color/light_gray" android:paddingHorizontal="8dp" android:paddingVertical="2dp"/>
                    <TextView android:id="@+id/tvTiempoAnticipacion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15 min antes" android:textSize="12sp" android:textColor="@color/gray" android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <!--  Botones aceptar/rechazar para invitaciones  -->
        <LinearLayout android:id="@+id/layoutAcciones" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp" android:visibility="gone" android:gravity="end">
            <Button android:id="@+id/btnRechazar" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Rechazar" android:textSize="12sp" android:backgroundTint="#E0E0E0" android:textColor="@color/black" android:layout_marginEnd="8dp" style="@style/Widget.MaterialComponents.Button.TextButton"/>
            <Button android:id="@+id/btnAceptar" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Aceptar" android:textSize="12sp" android:backgroundTint="@color/primary" android:textColor="@color/white"/>
        </LinearLayout>
        <!--  Estado de invitación ya respondida  -->
        <TextView android:id="@+id/tvEstadoInvitacion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textSize="13sp" android:visibility="gone"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>