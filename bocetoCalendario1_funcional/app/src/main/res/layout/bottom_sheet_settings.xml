<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet"
        android:paddingBottom="32dp">

        <!-- Handle -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_handle" />

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ajustes"
            android:textColor="@color/ink"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="16dp" />

        <!-- Timezone row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/rowZonaHoraria"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <FrameLayout android:layout_width="36dp" android:layout_height="36dp" android:layout_marginEnd="14dp">
                    <View android:layout_width="36dp" android:layout_height="36dp" android:background="#1A0B5FFF" android:backgroundTint="#1A0B5FFF" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="🌍" android:textSize="16sp" />
                </FrameLayout>

                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Zona horaria"
                    android:textColor="@color/ink" android:textSize="15sp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="UTC+2 ›" android:textColor="@color/muted" android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Week start toggle -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="LA SEMANA EMPIEZA EN"
            android:textColor="@color/muted" android:textSize="11sp" android:textStyle="bold"
            android:letterSpacing="0.1" android:paddingStart="20dp" android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="20dp"
            android:padding="4dp">

            <TextView
                android:id="@+id/btnSemanaLunes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Lunes"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_tab_active" />

            <TextView
                android:id="@+id/btnSemanaDomingo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Domingo"
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="@color/muted"
                android:background="@drawable/bg_tab_inactive" />

        </LinearLayout>

        <!-- Links card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp">

            <LinearLayout android:id="@+id/rowContactarSoporte"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="16dp" android:background="?attr/selectableItemBackground">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Contactar soporte"
                    android:textColor="@color/ink" android:textSize="15sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textColor="@color/muted" android:textSize="16sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/line_2" android:layout_marginStart="16dp" />

            <LinearLayout android:id="@+id/rowTerminos"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="16dp" android:background="?attr/selectableItemBackground">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Términos de uso"
                    android:textColor="@color/ink" android:textSize="15sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textColor="@color/muted" android:textSize="16sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/line_2" android:layout_marginStart="16dp" />

            <LinearLayout android:id="@+id/rowPrivacidad"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="16dp" android:background="?attr/selectableItemBackground">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Política de privacidad"
                    android:textColor="@color/ink" android:textSize="15sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textColor="@color/muted" android:textSize="16sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/line_2" android:layout_marginStart="16dp" />

            <LinearLayout android:id="@+id/rowAcercaDe"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:padding="16dp" android:background="?attr/selectableItemBackground">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Acerca de Calendario"
                    android:textColor="@color/ink" android:textSize="15sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textColor="@color/muted" android:textSize="16sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
