<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_group_blue"
    android:gravity="center_vertical">

    <!-- Avatar inicial del grupo -->
    <TextView
        android:id="@+id/tvInicialGrupo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="G"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="@drawable/bg_avatar"
        android:layout_marginEnd="14dp" />

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNombreGrupo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre del grupo"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tvDescripcionGrupo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descripción del grupo"
            android:textSize="13sp"
            android:textColor="#CCFFFFFF"
            android:maxLines="1"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvMiembros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ver grupo"
            android:textSize="12sp"
            android:textColor="#AAFFFFFF"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Flecha -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="›"
        android:textSize="26sp"
        android:textColor="#AAFFFFFF" />

</LinearLayout>
