<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_bottom_sheet" android:paddingBottom="16dp">
    <!--  Handle  -->
    <View android:layout_width="36dp" android:layout_height="4dp" android:layout_gravity="center_horizontal" android:layout_marginTop="12dp" android:layout_marginBottom="16dp" android:background="@drawable/bg_handle"/>
    <!--  Title  -->
    <TextView android:id="@+id/tvInviteTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Invitar al grupo" android:textColor="@color/ink" android:textSize="22sp" android:textStyle="bold" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingBottom="16dp"/>
    <!--  Search  -->
    <FrameLayout android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="12dp">
        <EditText android:id="@+id/etBuscarPersona" android:layout_width="match_parent" android:layout_height="48dp" android:hint="Buscar personas..." android:background="@drawable/bg_field" android:paddingStart="44dp" android:paddingEnd="16dp" android:textSize="14sp" android:textColor="@color/ink" android:textColorHint="@color/muted_2" android:singleLine="true"/>
        <TextView android:layout_width="36dp" android:layout_height="match_parent" android:text="🔍" android:textSize="15sp" android:gravity="center" android:layout_gravity="start|center_vertical"/>
    </FrameLayout>
    <!--  Email invite card  -->
    <LinearLayout android:id="@+id/cardInviteEmail" android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:background="@color/brand_50" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="16dp" android:padding="16dp">
        <TextView android:layout_width="24dp" android:layout_height="24dp" android:text="✉" android:textSize="14sp" android:textColor="@color/brand" android:gravity="center" android:layout_marginEnd="12dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Invitar por correo electrónico" android:textColor="@color/brand" android:textSize="14sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="→" android:textSize="16sp" android:textColor="@color/brand"/>
    </LinearLayout>
    <!--  Suggestions label  -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SUGERENCIAS" android:textColor="@color/muted" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.1" android:paddingStart="20dp" android:paddingBottom="8dp"/>
    <!--  Suggestions list (scroll)  -->
    <ScrollView android:layout_width="match_parent" android:layout_height="220dp">
        <LinearLayout android:id="@+id/layoutSuggestions" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="16dp"/>
    </ScrollView>
    <!--  Footer button  -->
    <Button android:id="@+id/btnInvitarPersonas" android:layout_width="match_parent" android:layout_height="52dp" android:text="Invitar" android:backgroundTint="@color/brand" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginTop="12dp"/>
</LinearLayout>