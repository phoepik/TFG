<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:padding="24dp">

        <!-- Logo section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="20dp">
                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_btn_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="📅"
                    android:textSize="36sp" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calendario"
                android:textColor="#0A1330"
                android:textSize="36sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Organiza tus planes, grupos y eventos en un solo lugar."
                android:textColor="#6B7494"
                android:textSize="15sp"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3" />

        </LinearLayout>

        <!-- Feature pills -->

        <!-- Pill 1: Comparte planes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="14dp">
                <View
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="#1AE94B7B"
                    android:backgroundTint="#1AE94B7B" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="👥"
                    android:textSize="18sp" />
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Comparte planes con tus grupos"
                android:textColor="#E94B7B"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Pill 2: Vista mes, semana y día -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="14dp">
                <View
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="#1A0B5FFF"
                    android:backgroundTint="#1A0B5FFF" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="📅"
                    android:textSize="18sp" />
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Vista mes, semana y día"
                android:textColor="#0B5FFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Pill 3: No te pierdas nada -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="14dp">
                <View
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="#1A22C55E"
                    android:backgroundTint="#1A22C55E" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🔔"
                    android:textSize="18sp" />
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No te pierdas nada"
                android:textColor="#22C55E"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Buttons -->
        <Button
            android:id="@+id/btnCrearCuenta"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Crear cuenta"
            android:backgroundTint="@color/brand"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnYaTengoCuenta"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Ya tengo cuenta"
            android:background="@drawable/bg_btn_ghost"
            android:textColor="@color/brand"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

</LinearLayout>
