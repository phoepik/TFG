<?xml version="1.0" encoding="utf-8"?>
<!--
    Tarjeta de un evento en la lista de Inicio.

    Diseño:
    ┌─┬──────────────────────────────────────┐
    │ │  Título del evento        [ESTADO]   │
    │▌│  Descripción breve                   │  ← barra de acento lateral
    │ │  📅 01/01/2026 10:00                 │
    │ │  📍 Ubicación                        │
    └─┴──────────────────────────────────────┘

    La barra de color a la izquierda indica el estado del evento.
    Su color se cambia desde el adaptador en tiempo de ejecución.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- ─── BARRA LATERAL DE ESTADO ─── -->
        <!-- Su color se actualiza desde el adaptador según el estado del evento -->
        <View
            android:id="@+id/viewEstadoAccent"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/green"
            android:minHeight="80dp"/>

        <!-- ─── CONTENIDO PRINCIPAL ─── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Fila superior: título + badge de estado -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <!-- Título del evento -->
                <TextView
                    android:id="@+id/tvTitulo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Título del evento"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginEnd="8dp"/>

                <!-- Badge de estado (ej. CONFIRMADO, PENDIENTE...) -->
                <TextView
                    android:id="@+id/tvEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONFIRMADO"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/green"
                    android:background="@drawable/bg_status_chip"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"/>

            </LinearLayout>

            <!-- Descripción breve -->
            <TextView
                android:id="@+id/tvDescripcion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción del evento"
                android:textSize="13sp"
                android:textColor="@color/gray"
                android:maxLines="2"
                android:layout_marginBottom="10dp"/>

            <!-- Fila: fecha de inicio -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 "
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvFechaInicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01/01/2026  10:00"
                    android:textSize="13sp"
                    android:textColor="@color/gray"/>

            </LinearLayout>

            <!-- Fila: ubicación -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 "
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvUbicacion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin ubicación"
                    android:textSize="13sp"
                    android:textColor="@color/gray"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
