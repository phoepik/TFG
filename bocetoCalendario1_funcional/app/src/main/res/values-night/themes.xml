<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema oscuro: hereda los estilos del tema principal.
         Los colores de superficie y fondo se adaptan automáticamente
         con DayNight si en el futuro se añade un colors-night.xml -->
    <style name="Theme.BocetoCalendario1" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="textInputStyle">@style/Widget.App.TextInput</item>
        <item name="materialButtonStyle">@style/Widget.App.Button.Primary</item>
    </style>
</resources>
